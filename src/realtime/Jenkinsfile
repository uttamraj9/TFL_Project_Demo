// Jenkinsfile for TfL Real-time Pipeline (Kafka + Spark Streaming)
// Jenkins at 51.24.13.205, Cloudera at 13.41.167.97, using SSH

pipeline {
    agent any

    parameters {
        choice(
            name: 'MODE',
            choices: ['both', 'producer', 'consumer'],
            description: 'Run producer, consumer, or both'
        )
        string(
            name: 'DURATION_MINUTES',
            defaultValue: '2',
            description: 'How long to run (minutes)'
        )
    }

    environment {
        CLOUDERA_HOST = '13.41.167.97'
        SSH_KEY = '/var/lib/jenkins/Desktop/Training/test_key.pem'
        PROJECT_DIR = '/home/consultant/uttam/TFL_Project_Demo'
        KAFKA_BROKERS = 'ip-172-31-8-235.eu-west-2.compute.internal:9092,ip-172-31-14-3.eu-west-2.compute.internal:9092'
        KAFKA_TOPIC = 'tfl_arrivals'
    }

    stages {
        stage('Checkout') {
            steps {
                echo '========================================='
                echo 'TfL Real-time Streaming Pipeline'
                echo '========================================='
                echo "Mode: ${params.MODE}"
                echo "Duration: ${params.DURATION_MINUTES} minutes"
                checkout scm
                sh 'git log -1 --oneline'
            }
        }

        stage('Deploy Scripts') {
            steps {
                echo '========================================='
                echo 'Deploy PySpark Scripts to Cloudera'
                echo '========================================='
                sh '''
                    # Create temp directory on Jenkins
                    mkdir -p /tmp/tfl_deploy_${BUILD_NUMBER}
                    cp src/realtime/*.py /tmp/tfl_deploy_${BUILD_NUMBER}/

                    # Copy to Cloudera via ec2-user
                    scp -i ${SSH_KEY} -o StrictHostKeyChecking=no \
                        /tmp/tfl_deploy_${BUILD_NUMBER}/*.py \
                        ec2-user@${CLOUDERA_HOST}:/tmp/

                    # Move to consultant directory
                    ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no \
                        ec2-user@${CLOUDERA_HOST} bash << 'DEPLOY_CMD'
                        sudo mkdir -p ${PROJECT_DIR}/src/realtime
                        sudo mv /tmp/*.py ${PROJECT_DIR}/src/realtime/ 2>/dev/null || true
                        sudo chown -R consultant:consultant ${PROJECT_DIR}/src/realtime
                        sudo chmod +x ${PROJECT_DIR}/src/realtime/*.py
                        echo "✓ Scripts deployed"
DEPLOY_CMD

                    # Cleanup temp
                    rm -rf /tmp/tfl_deploy_${BUILD_NUMBER}
                '''
            }
        }

        stage('Setup Kafka') {
            steps {
                echo '========================================='
                echo 'Create Kafka Topic'
                echo '========================================='
                sh '''
                    ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no \
                        ec2-user@${CLOUDERA_HOST} bash << 'KAFKA_CMD'
                        sudo -u consultant kafka-topics --create --if-not-exists \
                            --bootstrap-server ${KAFKA_BROKERS} \
                            --topic ${KAFKA_TOPIC} \
                            --partitions 3 \
                            --replication-factor 2 2>&1 || echo "Topic exists"
                        echo "✓ Kafka topic ready"
KAFKA_CMD
                '''
            }
        }

        stage('Run Producer') {
            when {
                expression { params.MODE == 'producer' || params.MODE == 'both' }
            }
            steps {
                echo '========================================='
                echo 'Start Kafka Producer (TfL API → Kafka)'
                echo '========================================='
                sh '''
                    ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ec2-user@${CLOUDERA_HOST} \
                        "sudo -u consultant bash -c 'cd ${PROJECT_DIR}/src/realtime && nohup timeout ${DURATION_MINUTES}m ./run_producer.sh > /tmp/producer_${BUILD_NUMBER}.log 2>&1 & echo ✓ Producer PID: \$!'"
                '''
            }
        }

        stage('Run Consumer') {
            when {
                expression { params.MODE == 'consumer' || params.MODE == 'both' }
            }
            steps {
                echo '========================================='
                echo 'Start Kafka Consumer (Kafka → HBase)'
                echo '========================================='
                sh '''
                    ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ec2-user@${CLOUDERA_HOST} \
                        "sudo -u consultant bash -c 'cd ${PROJECT_DIR}/src/realtime && nohup timeout ${DURATION_MINUTES}m spark-submit --master yarn --deploy-mode client --packages org.apache.spark:spark-sql-kafka-0-10_2.12:3.1.1 --conf spark.pyspark.python=/usr/bin/python3 write_kafka_to_hbase_native.py > /tmp/consumer_${BUILD_NUMBER}.log 2>&1 & echo ✓ Consumer PID: \$!'"
                '''
            }
        }

        stage('Monitor') {
            steps {
                echo '========================================='
                echo 'Monitor Streaming Pipeline'
                echo '========================================='
                sh '''
                    DURATION_SECONDS=$((${DURATION_MINUTES} * 60))
                    echo "Running for ${DURATION_MINUTES} minutes..."

                    sleep 30
                    echo "Status check:"
                    ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no \
                        ec2-user@${CLOUDERA_HOST} \
                        "sudo -u consultant hdfs dfs -ls /tmp/uttam/kafka/tfl_arrivals/data/ 2>&1 | tail -5" || echo "No data yet"

                    REMAINING=$((DURATION_SECONDS - 30))
                    [ $REMAINING -gt 0 ] && sleep $REMAINING
                    echo "✓ Duration complete"
                '''
            }
        }

        stage('Verify Results') {
            steps {
                echo '========================================='
                echo 'Verify HBase Output'
                echo '========================================='
                sh '''
                    ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no \
                        ec2-user@${CLOUDERA_HOST} "sudo -u consultant bash << 'VERIFY_CMD'
                        echo 'HBase Table: tfl_arrivals'
                        echo \"count 'tfl_arrivals'\" | hbase shell -n 2>&1 | tail -2
                        echo ''
                        echo 'Sample Records:'
                        echo \"scan 'tfl_arrivals', {LIMIT => 2}\" | hbase shell -n 2>&1 | grep -A 10 COLUMN+CELL | head -15
VERIFY_CMD
"
                '''
            }
        }

        stage('Cleanup') {
            steps {
                echo '========================================='
                echo 'Stop Streaming Jobs (Optional - keep running)'
                echo '========================================='
                sh '''
                    echo "Note: Pipeline jobs left running for continuous streaming"
                    echo "To stop manually: ssh to Cloudera and pkill -9 -f send_data_to_kafka.py"
                    echo "✓ Build complete"
                '''
            }
        }
    }

    post {
        success {
            echo '========================================='
            echo '✓✓✓ PIPELINE COMPLETED SUCCESSFULLY ✓✓✓'
            echo '========================================='
            echo "Mode: ${params.MODE}"
            echo "Duration: ${params.DURATION_MINUTES} minutes"
            echo "Kafka Topic: ${env.KAFKA_TOPIC}"
            echo "HBase Table: tfl_arrivals"
            echo "Data Flow: TfL API → Kafka → HBase"
            echo '========================================='
        }
        failure {
            echo '========================================='
            echo '✗✗✗ PIPELINE FAILED ✗✗✗'
            echo '========================================='
            echo "Mode: ${params.MODE}"
            echo ""
            echo "Check logs on ${env.CLOUDERA_HOST}:"
            echo "  Producer: /tmp/producer_${BUILD_NUMBER}.log"
            echo "  Consumer: /tmp/consumer_${BUILD_NUMBER}.log"
            echo '========================================='
        }
        always {
            echo 'Pipeline execution completed'
        }
    }
}
