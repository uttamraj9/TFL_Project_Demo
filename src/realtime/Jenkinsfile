// Jenkinsfile for TfL Real-time Pipeline (Kafka + Spark + HBase)
// Location: src/realtime/Jenkinsfile

pipeline {
    agent any

    parameters {
        choice(
            name: 'MODE',
            choices: ['producer', 'consumer_hbase', 'both'],
            description: 'Run producer, HBase consumer, or both'
        )
        string(
            name: 'DURATION_MINUTES',
            defaultValue: '5',
            description: 'How long to run (minutes)'
        )
    }

    environment {
        REMOTE_HOST = '13.41.167.97'
        REMOTE_USER = 'consultant'
        REMOTE_PASSWORD = 'WelcomeItc@2026'
        PROJECT_DIR = '/home/consultant/uttam/TFL_Project_Demo'
        REALTIME_DIR = '${PROJECT_DIR}/src/realtime'

        KAFKA_BROKERS = 'ip-172-31-6-42.eu-west-2.compute.internal:9092,ip-172-31-3-251.eu-west-2.compute.internal:9092,ip-172-31-3-85.eu-west-2.compute.internal:9092,ip-172-31-12-74.eu-west-2.compute.internal:9092'
        KAFKA_TOPIC = 'tfl_arrivals'
        HBASE_TABLE = 'tfl_arrivals'
        HBASE_MASTER = 'ip-172-31-12-74.eu-west-2.compute.internal'

        PYSPARK_PYTHON = '/usr/bin/python3'

        CM_API = 'http://13.41.167.97:7180/api/v40'
        CM_USER = 'admin'
        CM_PASS = 'Admin@2026'
    }

    stages {
        stage('Check Services via CM API') {
            steps {
                echo '========================================='
                echo 'Check Kafka & HBase via Cloudera Manager API'
                echo '========================================='
                sh '''
                    echo "Checking Kafka status..."
                    KAFKA_STATE=$(curl -s -u "${CM_USER}:${CM_PASS}" \
                        "${CM_API}/clusters/Cluster%201/services/kafka" | \
                        python3 -c "import json,sys; print(json.load(sys.stdin)['serviceState'])")
                    echo "Kafka: $KAFKA_STATE"

                    if [ "$KAFKA_STATE" != "STARTED" ]; then
                        echo "Starting Kafka..."
                        curl -X POST -u "${CM_USER}:${CM_PASS}" \
                            "${CM_API}/clusters/Cluster%201/services/kafka/commands/start"
                        sleep 30
                    fi

                    echo "Checking HBase status..."
                    HBASE_STATE=$(curl -s -u "${CM_USER}:${CM_PASS}" \
                        "${CM_API}/clusters/Cluster%201/services/hbase" | \
                        python3 -c "import json,sys; print(json.load(sys.stdin)['serviceState'])" 2>/dev/null || echo "N/A")
                    echo "HBase: $HBASE_STATE"

                    if [ "$HBASE_STATE" = "STOPPED" ]; then
                        echo "Starting HBase..."
                        curl -X POST -u "${CM_USER}:${CM_PASS}" \
                            "${CM_API}/clusters/Cluster%201/services/hbase/commands/start"
                        sleep 30
                    fi

                    echo "✓ Services checked"
                '''
            }
        }

        stage('Checkout & Deploy') {
            steps {
                echo '========================================='
                echo 'Deploy PySpark Scripts'
                echo '========================================='
                checkout scm
                sh '''
                    sshpass -p "${REMOTE_PASSWORD}" ssh -o StrictHostKeyChecking=no \
                        -o UserKnownHostsFile=/dev/null ${REMOTE_USER}@${REMOTE_HOST} \
                        "mkdir -p ${REALTIME_DIR}"

                    sshpass -p "${REMOTE_PASSWORD}" scp -o StrictHostKeyChecking=no \
                        -o UserKnownHostsFile=/dev/null src/realtime/*.py \
                        ${REMOTE_USER}@${REMOTE_HOST}:${REALTIME_DIR}/

                    sshpass -p "${REMOTE_PASSWORD}" ssh -o StrictHostKeyChecking=no \
                        -o UserKnownHostsFile=/dev/null ${REMOTE_USER}@${REMOTE_HOST} \
                        "chmod +x ${REALTIME_DIR}/*.py"

                    echo "✓ Scripts deployed"
                '''
            }
        }

        stage('Create HBase Table') {
            steps {
                echo '========================================='
                echo 'Create HBase Table'
                echo '========================================='
                sh '''
                    sshpass -p "${REMOTE_PASSWORD}" ssh -o StrictHostKeyChecking=no \
                        -o UserKnownHostsFile=/dev/null ${REMOTE_USER}@${REMOTE_HOST} bash << 'HBASE_SCRIPT'

echo "create '${HBASE_TABLE}', 'cf'" | hbase shell 2>&1 || echo "Table may exist"

echo "✓ HBase table ready: ${HBASE_TABLE}"
HBASE_SCRIPT
                '''
            }
        }

        stage('Create Kafka Topic') {
            steps {
                echo '========================================='
                echo 'Create Kafka Topic'
                echo '========================================='
                sh '''
                    sshpass -p "${REMOTE_PASSWORD}" ssh -o StrictHostKeyChecking=no \
                        -o UserKnownHostsFile=/dev/null ${REMOTE_USER}@${REMOTE_HOST} \
                        "kafka-topics --create --if-not-exists \
                        --bootstrap-server ${KAFKA_BROKERS} \
                        --topic ${KAFKA_TOPIC} \
                        --partitions 3 \
                        --replication-factor 2" 2>&1 || echo "✓ Topic exists"
                '''
            }
        }

        stage('Run Producer') {
            when {
                expression { params.MODE == 'producer' || params.MODE == 'both' }
            }
            steps {
                echo '========================================='
                echo 'Start Producer (TfL API → Kafka)'
                echo '========================================='
                sh '''
                    sshpass -p "${REMOTE_PASSWORD}" ssh -o StrictHostKeyChecking=no \
                        -o UserKnownHostsFile=/dev/null ${REMOTE_USER}@${REMOTE_HOST} bash << 'PRODUCER'
cd ${REALTIME_DIR}
pkill -9 -f send_data_to_kafka || true

timeout ${DURATION_MINUTES}m spark-submit \
  --master yarn \
  --deploy-mode client \
  --num-executors 1 \
  --executor-memory 512M \
  --packages org.apache.spark:spark-sql-kafka-0-10_2.12:3.1.1 \
  --conf spark.pyspark.python=${PYSPARK_PYTHON} \
  send_data_to_kafka.py 2>&1 | tee /tmp/producer.log &

echo "✓ Producer started"
PRODUCER
                '''
            }
        }

        stage('Run HBase Consumer') {
            when {
                expression { params.MODE == 'consumer_hbase' || params.MODE == 'both' }
            }
            steps {
                echo '========================================='
                echo 'Start Consumer (Kafka → HBase)'
                echo '========================================='
                sh '''
                    sshpass -p "${REMOTE_PASSWORD}" ssh -o StrictHostKeyChecking=no \
                        -o UserKnownHostsFile=/dev/null ${REMOTE_USER}@${REMOTE_HOST} bash << 'CONSUMER'
cd ${REALTIME_DIR}
pkill -9 -f read_from_kafka_hbase || true

hdfs dfs -rm -r -f -skipTrash /tmp/uttam/kafka/tfl_hbase/checkpoint

timeout ${DURATION_MINUTES}m spark-submit \
  --master yarn \
  --deploy-mode client \
  --num-executors 1 \
  --executor-memory 512M \
  --packages org.apache.spark:spark-sql-kafka-0-10_2.12:3.1.1,org.apache.hbase.connectors.spark:hbase-spark:1.0.0 \
  --conf spark.pyspark.python=${PYSPARK_PYTHON} \
  read_from_kafka_hbase.py 2>&1 | tee /tmp/consumer_hbase.log &

echo "✓ HBase Consumer started"
CONSUMER
                '''
            }
        }

        stage('Monitor') {
            steps {
                echo "Running for ${params.DURATION_MINUTES} minutes..."
                sh 'sleep $((${DURATION_MINUTES} * 60))'
            }
        }

        stage('Verify HBase Data') {
            steps {
                echo '========================================='
                echo 'Verify HBase Table Data'
                echo '========================================='
                sh '''
                    sshpass -p "${REMOTE_PASSWORD}" ssh -o StrictHostKeyChecking=no \
                        -o UserKnownHostsFile=/dev/null ${REMOTE_USER}@${REMOTE_HOST} bash << 'VERIFY'

echo "count '${HBASE_TABLE}'" | hbase shell 2>&1 | grep -E "row|second"

echo ""
echo "Sample records:"
echo "scan '${HBASE_TABLE}', {LIMIT => 5}" | hbase shell 2>&1 | head -30

VERIFY
                '''
            }
        }

        stage('Cleanup') {
            steps {
                sh '''
                    sshpass -p "${REMOTE_PASSWORD}" ssh -o StrictHostKeyChecking=no \
                        -o UserKnownHostsFile=/dev/null ${REMOTE_USER}@${REMOTE_HOST} \
                        "pkill -9 -f send_data_to_kafka || true; \
                         pkill -9 -f read_from_kafka_hbase || true"
                    echo "✓ Jobs stopped"
                '''
            }
        }
    }

    post {
        success {
            echo '========================================='
            echo '✓✓✓ REAL-TIME PIPELINE COMPLETED ✓✓✓'
            echo '========================================='
            echo "Kafka Topic: ${KAFKA_TOPIC}"
            echo "HBase Table: ${HBASE_TABLE}"
            echo ""
            echo "Query HBase:"
            echo "  ssh ${REMOTE_USER}@${REMOTE_HOST}"
            echo "  hbase shell"
            echo "  scan '${HBASE_TABLE}', {LIMIT => 10}"
            echo '========================================='
        }
        failure {
            echo '✗✗✗ PIPELINE FAILED ✗✗✗'
        }
    }
}
